# Copy this file to ".env" and fill in the values.
# docker-compose reads ".env" automatically.

# Password for the bundled Postgres container.
POSTGRES_PASSWORD=change-me-local-password

# Host port the site is exposed on (http://localhost:PORT).
PORT=8000

# ------------------------------------------------------------------
# GoCardless — Direct Debit payments
# Leave ACCESS_TOKEN blank to run in "setup mode": the whole site works
# and the timetable is live, but the join/pay buttons stay disabled.
# ------------------------------------------------------------------
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_WEBHOOK_ENDPOINT_SECRET=

# ------------------------------------------------------------------
# Member login by email (one-time sign-in codes, free via any SMTP mailbox)
# Works with a Gmail app password, an Office365/other mailbox, or any
# SMTP relay. Port 587 = STARTTLS (default), 465 = SSL.
# SMTP_FROM defaults to SMTP_USERNAME when blank.
# ------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ------------------------------------------------------------------
# Optional: member login by mobile (WhatsApp / SMS codes via Twilio Verify)
# Leave blank to use email-only member login.
# Create a Verify service in the Twilio console and paste its SID (VA...).
# ------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ------------------------------------------------------------------
# Studio administration
# A long random string. Required to publish / manage classes through the
# "Studio login" panel in the site footer.
# ------------------------------------------------------------------
ORTU_FITNESS_ADMIN_KEY=

# ------------------------------------------------------------------
# Public URL of the deployed site (used for GoCardless return links).
# Leave blank locally. In production set it to the real address, e.g.
# https://book.ortufitness.co.uk
# ------------------------------------------------------------------
ORTU_FITNESS_PUBLIC_URL=

# ------------------------------------------------------------------
# AI chat assistant integration (server-to-server key for /api/agent/*).
# A long random string; the chat platform sends it as X-Ortu-Agent-Key.
# Leave blank to disable the assistant's member/booking abilities.
# ------------------------------------------------------------------
ORTU_FITNESS_AGENT_KEY=
