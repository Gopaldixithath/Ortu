# Copy this file to ".env" and fill in the values.
# docker-compose reads ".env" automatically.

# Password for the bundled Postgres container.
POSTGRES_PASSWORD=change-me-local-password

# Host port the site is exposed on (http://localhost:PORT).
PORT=8000

# ------------------------------------------------------------------
# GoCardless — Direct Debit payments
# Leave ACCESS_TOKEN blank to run in "setup mode": the whole site works
# and the timetable is live, but the join/pay buttons stay disabled.
# ------------------------------------------------------------------
GOCARDLESS_ENVIRONMENT=sandbox
GOCARDLESS_ACCESS_TOKEN=
GOCARDLESS_WEBHOOK_ENDPOINT_SECRET=

# ------------------------------------------------------------------
# Studio administration
# A long random string. Required to publish / manage classes through the
# "Studio login" panel in the site footer.
# ------------------------------------------------------------------
ORTU_FITNESS_ADMIN_KEY=

# ------------------------------------------------------------------
# Public URL of the deployed site (used for GoCardless return links).
# Leave blank locally. In production set it to the real address, e.g.
# https://book.ortufitness.co.uk
# ------------------------------------------------------------------
ORTU_FITNESS_PUBLIC_URL=
